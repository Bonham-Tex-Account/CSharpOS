<Project Sdk="Microsoft.NET.Sdk">

  <!-- Standalone helper for the os-facts skill: references the core library and reflects over
       its public const ints so the skill can print ground-truth layout/IVT/entry numbers.
       NOT part of CSharpOS.slnx; built on demand by the skill's dotnet run command. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>osfacts</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\CSharpOS\CSharpOS.csproj" />
  </ItemGroup>

</Project>
